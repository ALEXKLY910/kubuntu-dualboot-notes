#!/usr/bin/env bash
set -euo pipefail

DAC_DEV="/dev/snd/by-id/usb-TTGK_Technology_Co._Ltd_CX31993_384Khz_HIFI_AUDIO-00"
DAC_SINK="alsa_output.usb-TTGK_Technology_Co._Ltd_CX31993_384Khz_HIFI_AUDIO-00.analog-stereo"
BUILTIN_SINK="alsa_output.pci-0000_10_00.6.analog-stereo"
NOVA_SINK="nova_fx"

ACTION="${1:-}"
STEP_RAW="${2:-5%}"

if [[ "$ACTION" != "mute" && "$ACTION" != "fix" && ! "$STEP_RAW" =~ ^[0-9]+%$ ]]; then
  echo "Step must be like 5% or 10% (got: $STEP_RAW)"
  exit 1
fi

STEP="${STEP_RAW%\%}"

real_sink() {
  if [[ -e "$DAC_DEV" ]] && pactl list short sinks | awk '{print $2}' | grep -qx "$DAC_SINK"; then
    printf '%s\n' "$DAC_SINK"
  else
    printf '%s\n' "$BUILTIN_SINK"
  fi
}

get_vol() {
  pactl get-sink-volume "$1" | grep -oE '[0-9]+%' | head -n1 | tr -d '%'
}

set_vol_clamped() {
  local sink="$1"
  local target="$2"

  (( target < 0 )) && target=0
  (( target > 100 )) && target=100

  pactl set-sink-volume "$sink" "${target}%"
}

SINK="$(real_sink)"

case "$ACTION" in
  up)
    CUR="$(get_vol "$SINK")"
    set_vol_clamped "$SINK" "$((CUR + STEP))"
    ;;
  down)
    CUR="$(get_vol "$SINK")"
    set_vol_clamped "$SINK" "$((CUR - STEP))"
    ;;
  mute)
    pactl set-sink-mute "$SINK" toggle
    ;;
  fix)
    pactl set-sink-volume "$NOVA_SINK" 100% || true
    pactl set-sink-mute "$NOVA_SINK" 0 || true
    ;;
  *)
    echo "Usage: audio-volume {up|down|mute|fix} [STEP%]"
    echo "Example: audio-volume up 5%"
    exit 1
    ;;
esac

pactl set-sink-volume "$NOVA_SINK" 100% 2>/dev/null || true
