#!/usr/bin/env bash
set -euo pipefail

ACTION="${1:-toggle}"

STATE="${XDG_CACHE_HOME:-$HOME/.cache}/audio-mode"

CARLA_PROJECT="$HOME/.config/carla/nova.carxp"
WINELOADER_PATH="$HOME/.local/share/wine-builds/wine-9.21-staging-tkg-amd64/bin/wine"

DAC_DEV="/dev/snd/by-id/usb-TTGK_Technology_Co._Ltd_CX31993_384Khz_HIFI_AUDIO-00"
DAC_SINK="alsa_output.usb-TTGK_Technology_Co._Ltd_CX31993_384Khz_HIFI_AUDIO-00.analog-stereo"
BUILTIN_SINK="alsa_output.pci-0000_10_00.6.analog-stereo"
NOVA_SINK="nova_fx"

mkdir -p "$(dirname "$STATE")"

real_sink() {
  if [[ -e "$DAC_DEV" ]] && pactl list short sinks | awk '{print $2}' | grep -qx "$DAC_SINK"; then
    printf '%s\n' "$DAC_SINK"
  else
    printf '%s\n' "$BUILTIN_SINK"
  fi
}

move_all_inputs() {
  local dst="$1"

  pactl list short sink-inputs | awk '{print $1}' | while read -r id; do
    pactl move-sink-input "$id" "$dst" || true
  done
}

sink_id_by_name() {
  pactl list short sinks | awk -v name="$1" '$2 == name {print $1; exit}'
}

move_inputs_from_sink() {
  local src_name="$1"
  local dst_name="$2"
  local src_id

  src_id="$(sink_id_by_name "$src_name")"
  [[ -n "$src_id" ]] || return 0

  pactl list short sink-inputs | awk -v sid="$src_id" '$2 == sid {print $1}' | while read -r input_id; do
    pactl move-sink-input "$input_id" "$dst_name" || true
  done
}

carla_running() {
  pgrep -f '(/usr/share/carla/carla|/usr/bin/carla)' >/dev/null
}

stop_carla() {
  pkill -f '(/usr/share/carla/carla|/usr/bin/carla)' || true

  for _ in {1..40}; do
    carla_running || return 0
    sleep 0.1
  done
}

stop_qpwgraph() {
  pkill -x qpwgraph || true

  for _ in {1..30}; do
    pgrep -x qpwgraph >/dev/null || return 0
    sleep 0.1
  done
}

ensure_nova_sink() {
  if ! pactl list short sinks | awk '{print $2}' | grep -qx "$NOVA_SINK"; then
    pactl load-module module-null-sink \
      sink_name="$NOVA_SINK" \
      sink_properties=device.description=NovaFX >/dev/null
    sleep 1
  fi

  pactl set-sink-volume "$NOVA_SINK" 100% || true
  pactl set-sink-mute "$NOVA_SINK" 0 || true
}

notify_mode() {
  command -v notify-send >/dev/null 2>&1 || return 0
  notify-send "Audio mode" "$1"
}

wait_for_pipewire() {
  for _ in {1..40}; do
    if pactl info >/dev/null 2>&1 && pw-link -i >/dev/null 2>&1; then
      return 0
    fi
    sleep 0.25
  done

  echo "PipeWire/PulseAudio did not become ready"
  return 1
}

carla_ports_ready() {
  pw-link -i | grep -qx 'Carla:audio-in1' &&
  pw-link -i | grep -qx 'Carla:audio-in2' &&
  pw-link -o | grep -qx 'Carla:audio-out1' &&
  pw-link -o | grep -qx 'Carla:audio-out2'
}

start_carla() {
  WINELOADER="$WINELOADER_PATH" pw-jack carla "$CARLA_PROJECT" >/tmp/carla-nova.log 2>&1 &
}

ensure_carla_ready() {
  if carla_ports_ready; then
    return 0
  fi

  if carla_running; then
    stop_carla
    sleep 1
  fi

  for attempt in 1 2 3; do
    start_carla

    for _ in {1..40}; do
      if carla_ports_ready; then
        return 0
      fi
      sleep 0.25
    done

    stop_carla
    sleep 1
  done

  notify_mode "Carla failed to expose audio ports"
  echo "Carla failed to expose audio ports. Check /tmp/carla-nova.log"
  return 1
}

case "$ACTION" in
  auto)
    if [[ -f "$STATE" ]]; then
      ACTION="$(<"$STATE")"
    else
      ACTION="normal"
    fi
    ;;
  toggle)
    if [[ -f "$STATE" && "$(cat "$STATE")" == "nova" ]]; then
      ACTION="normal"
    else
      ACTION="nova"
    fi
    ;;
esac

case "$ACTION" in
  nova)
    wait_for_pipewire
    ensure_nova_sink
    ensure_carla_ready

    "$HOME/.local/bin/qpwgraph-select-audio" || true
    systemctl --user start dac-hotplug.path || true

    sleep 0.5
    pactl set-default-sink "$NOVA_SINK"
    move_all_inputs "$NOVA_SINK"
    sleep 0.3
    move_all_inputs "$NOVA_SINK"

    printf 'nova\n' > "$STATE"
    notify_mode "Nova mode enabled"
    ;;

  normal)
    REAL_SINK="$(real_sink)"

    systemctl --user stop dac-hotplug.path qpwgraph.service || true
    stop_qpwgraph
    stop_carla
    sleep 0.5

    pactl set-default-sink "$REAL_SINK"

    for _ in {1..6}; do
      move_inputs_from_sink "$NOVA_SINK" "$REAL_SINK"
      sleep 0.2
    done

    move_all_inputs "$REAL_SINK"
    sleep 0.2
    move_all_inputs "$REAL_SINK"

    printf 'normal\n' > "$STATE"
    notify_mode "Normal mode enabled"
    ;;

  *)
    echo "Usage: audio-mode {toggle|nova|normal|auto}"
    exit 1
    ;;
esac
